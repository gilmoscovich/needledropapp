{
  "expo": {
    "name": "Needle Drop",
    "slug": "needledrop",
    "scheme": "needledrop",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#131313"
    },
    "ios": {
      "bundleIdentifier": "com.yourname.needledrop",
      "supportsTablet": false
    },
    "android": {
      "package": "com.yourname.needledrop",
      "adaptiveIcon": {
        "backgroundColor": "#131313"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      "expo-web-browser"
    ]
  }
}
